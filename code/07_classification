#R code for classifyng images

library(terra)
library(imageRy)

im.list()

#prendere
#"Solar_Orbiter_s_first_views_of_the_Sun_pillars.jpg" 
#rap. 3 diversi livelli energetici del sole da classificare per i tre livelli attraverso im.classify()

sun<-im.import("Solar_Orbiter_s_first_views_of_the_Sun_pillars.jpg")

?im.classify() #im.classify(  ùinput_image, num_clusters = 3, seed = NULL,..) num_clusters=numero classi , seed= prima iterazione, in default è NULL

im.classify(sun,3)
#colori strani perchè la classificazione parte da un certo punto del grafico e possono quindi essere leggermente diversi, procedura detta iterativa
#si può scegliere la prima iterazione attraverso "seed"<- si classifica con un numero
#
im.classify(sun,num_clusters=3,seed=19)

#gran canyon classification

im.list()
# e prendere :   "dolansprings_oli_2013088_canyon_lrg.jpg" 

can<-im.import("dolansprings_oli_2013088_canyon_lrg.jpg")
